# PostgreSQL password for the bonsai database user.
# Default: bonsai (change in production)
POSTGRES_PASSWORD=bonsai-skjgksajhgajfdhg-secret

# JWT secret used by bonsai-backend to sign and verify tokens.
# REQUIRED. Must be at least 32 characters long.
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# Runtime environment. Use "production" for production deployments.
NODE_ENV=production

# Host port on which the backend API is exposed.
# Default: 3000
BACKEND_PORT=3000

# Host port on which the admin panel is exposed.
# Default: 80
ADMIN_PORT=80

# Host port on which the backend API documentation is exposed.
# Default: 8080
DOCS_PORT=8080

# Allowed CORS origin for the backend.
# Set to a specific domain in production (e.g., https://admin.example.com).
# Default: * (all origins)
CORS_ORIGIN=*

# Database connection pool size.
# Default: 10
DB_POOL_SIZE=10

# Log level for the backend: trace, debug, info, warn, error, fatal.
# Default: info
LOG_LEVEL=info

# Rate limiting for authentication endpoints (POST /api/auth/login, POST /api/auth/refresh).
# Window in milliseconds and max requests per IP within that window.
# Default: 10 attempts per 15 minutes
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# Rate limiting for the general API.
# Window in milliseconds and max requests per authenticated operator (or IP if unauthenticated).
# Default: 300 requests per minute
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300
